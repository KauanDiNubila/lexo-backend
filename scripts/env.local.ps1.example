# Copie este arquivo para "env.local.ps1" (no mesmo diretorio) e cole sua chave.
# O env.local.ps1 e ignorado pelo Git (nao vai para o repositorio).
# O start-all.ps1 carrega este arquivo automaticamente antes de subir os servicos.
#
# Chave gratis: https://aistudio.google.com -> "Get API key" (sem cartao de credito).

$env:GEMINI_API_KEY = "cole-sua-chave-aqui"

# Opcional: trocar o modelo (padrao gemini-1.5-flash)
# $env:GEMINI_MODEL = "gemini-1.5-flash"
